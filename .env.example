POSTGRES_PASSWORD=offerguard
MINIO_ROOT_USER=offerguard
MINIO_ROOT_PASSWORD=offerguard-local-secret

OFFERGUARD_DATABASE_URL=postgresql+asyncpg://offerguard:offerguard@postgres:5432/offerguard
OFFERGUARD_VECTOR_STORE=weaviate
OFFERGUARD_VECTOR_HOST=weaviate
OFFERGUARD_VECTOR_HTTP_PORT=8080
OFFERGUARD_VECTOR_GRPC_PORT=50051
OFFERGUARD_STARTUP_CHECK_TIMEOUT_SECONDS=5.0
OFFERGUARD_MAX_UPLOAD_BYTES=10485760
OFFERGUARD_ALLOWED_UPLOAD_EXTENSIONS=.txt,.md,.markdown,.pdf
OFFERGUARD_RULE_BASE_PATH=/app/knowledge_base/uae_employment_rules.v1.json
OFFERGUARD_EMBEDDING_PROVIDER=openai
OFFERGUARD_EMBEDDING_MODEL=openai/text-embedding-3-small
OFFERGUARD_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
OFFERGUARD_EMBEDDING_DIMENSIONS=1536
OFFERGUARD_EMBEDDING_TIMEOUT_SECONDS=30
OFFERGUARD_EMBEDDING_MAX_RETRIES=3
OFFERGUARD_EMBEDDING_RETRY_MIN_SECONDS=2
OFFERGUARD_EMBEDDING_RETRY_MAX_SECONDS=20
VITE_API_BASE_URL=/api

# Use OFFERGUARD_EMBEDDING_PROVIDER=hash for offline local indexing tests.
# OFFERGUARD_OPENROUTER_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_TRACING_V2=true
# LANGSMITH_API_KEY=
LANGSMITH_PROJECT=offerguard-ai-local
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=offerguard-ai-local
